# Required: NVIDIA API key from build.nvidia.com
NVIDIA_API_KEY=<your-nvidia-api-key>

# Model config (defaults shown)
NEMOCLAW_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOCLAW_PROVIDER=default
NEMOCLAW_PROVIDER_TYPE=nvidia
NEMOCLAW_INFERENCE_ENDPOINT=https://integrate.api.nvidia.com/v1

# Qdrant Edge config
QDRANT_URL=http://127.0.0.1:6333
QDRANT_BRIDGE_PORT=6333
QDRANT_COLLECTION=agent_memory
QDRANT_STORAGE_DIR=/var/lib/qdrant-edge

# Optional: chat bot tokens
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# Port (Render sets this automatically)
PORT=18789
